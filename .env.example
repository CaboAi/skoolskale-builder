# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle (direct Postgres connection, not the pooler)
DATABASE_URL=

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# Google AI — Gemini image generation (Nano Banana family)
# Get key at https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Set to 1 for local dev with `inngest-cli dev`. Leave unset in production.
INNGEST_DEV=1

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email allowlist (comma-separated, no spaces)
TEAM_EMAIL_ALLOWLIST=mario@example.com,ramsha@skoolskale.com,domenic@skoolskale.com

