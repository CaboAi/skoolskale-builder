# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle (direct Postgres connection, not the pooler)
DATABASE_URL=

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# Google AI — Gemini image generation (Nano Banana family)
# Get key at https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Set to 1 for local dev with `inngest-cli dev`. Leave unset in production.
INNGEST_DEV=1

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email allowlist (comma-separated, no spaces). Add demo email defensively
# even though /auth/callback is bypassed in demo mode.
TEAM_EMAIL_ALLOWLIST=mario@example.com,ramsha@skoolskale.com,domenic@skoolskale.com,demo@skoolskale.app

# Demo mode — set DEMO_MODE=1 to auto-mint a Supabase session for the
# DEMO_USER_EMAIL on every unauthed request. Off in tests + prod once a
# real auth flow is in place. DEMO_USER_ID must match the auth.users row
# seeded by `pnpm demo:seed`. Server-only — do NOT prefix with NEXT_PUBLIC_.
DEMO_MODE=0
DEMO_USER_EMAIL=demo@skoolskale.app
DEMO_USER_ID=1842cd82-3441-4595-ac7a-7becb2618481

# Deferred until Sprint 4
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Deferred until Sprint 9
# CANVA_CLIENT_ID=
# CANVA_CLIENT_SECRET=
# CANVA_REDIRECT_URI=http://localhost:3000/api/admin/canva/oauth/callback
